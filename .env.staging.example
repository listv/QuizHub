# ══════════════════════════════════════
# Staging environment variables
# Copy to .env.staging
# ══════════════════════════════════════

# PostgreSQL
DB_PASSWORD=staging_password

# JWT (min 32 chars)
JWT_KEY=your-staging-jwt-key-different-from-prod

# GitHub Container Registry owner
GITHUB_OWNER=your-github-username

# pgAdmin (optional)
PGADMIN_PASSWORD=admin
