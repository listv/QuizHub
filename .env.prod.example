# ══════════════════════════════════════
# Production environment variables
# Copy to .env for production
# ══════════════════════════════════════

# PostgreSQL
DB_PASSWORD=your_secure_production_password

# JWT (min 32 chars)
JWT_KEY=your-super-secret-production-jwt-key-32-chars

# GitHub Container Registry owner (your GitHub username or org)
GITHUB_OWNER=your-github-username

# pgAdmin (optional, --profile tools)
PGADMIN_PASSWORD=admin
