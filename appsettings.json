{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=quizhub;Username=postgres;Password=postgres"
  },
  "Jwt": {
    "Key": "QuizHub-Super-Secret-Key-Must-Be-At-Least-32-Characters-Long!",
    "Issuer": "QuizHub",
    "Audience": "QuizHub"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    }
  },
  "RateLimiting": {
    "General": {
